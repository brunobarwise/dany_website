---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Gallery from '../../components/Gallery.astro';
import GalleryModal from '../../components/GalleryModal.astro';
import Amenities from '../../components/Amenities.astro';
import Map from '../../components/Map.astro';
import Reviews from '../../components/Reviews.astro';
import SchemaLodging from '../../components/SchemaLodging.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n';

const lang = 'en' as const;
const t = useTranslations(lang);
const description = t('meta.home.description');
---
<Base
  lang={lang}
  title={t('meta.home.title')}
  description={description}
  preloadHero
>
  <SchemaLodging lang={lang} description={description} />
  <Nav lang={lang} currentUrl={Astro.url} />
  <main class="pt-16">
    <Hero lang={lang} />
    <Gallery lang={lang} />
    <Amenities lang={lang} />
    <Map lang={lang} />
    <Reviews lang={lang} />
  </main>
  <GalleryModal lang={lang} />
  <Footer lang={lang} />
</Base>
