---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en' as const;
---
<Base
  lang={lang}
  title="Legal notice — Étoile de la Mer"
  description="Legal notice and privacy policy for location-etoiledelamer-capdagde.fr"
>
  <Nav lang={lang} currentUrl={Astro.url} />
  <main class="pt-16">
    <div class="bg-mer-dark text-white py-16 px-4">
      <div class="max-w-3xl mx-auto">
        <h1 class="font-display text-5xl font-bold">Legal notice</h1>
      </div>
    </div>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 space-y-12 text-dusk/80 leading-relaxed">

      <section>
        <h2 class="font-display text-2xl text-dusk mb-4">Website publisher</h2>
        <p>
          This website is published by a private individual.
        </p>
        <ul class="mt-3 space-y-1 text-sm">
          <li><span class="font-semibold text-dusk">Name:</span> Danielle Duchenne</li>
          <li><span class="font-semibold text-dusk">Address:</span> 5 rue des Tisserands, 34800 Villeneuvette, France</li>
          <li><span class="font-semibold text-dusk">Email:</span> <a href="mailto:dany@location-etoiledelamer-capdagde.fr" class="text-mer hover:underline">dany@location-etoiledelamer-capdagde.fr</a></li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-2xl text-dusk mb-4">Hosting</h2>
        <ul class="space-y-1 text-sm">
          <li><span class="font-semibold text-dusk">Host:</span> Vercel Inc.</li>
          <li><span class="font-semibold text-dusk">Address:</span> 340 Pine Street Suite 701, San Francisco, CA 94104, United States</li>
          <li><span class="font-semibold text-dusk">Website:</span> <a href="https://vercel.com" target="_blank" rel="noopener noreferrer" class="text-mer hover:underline">vercel.com</a></li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-2xl text-dusk mb-4">Privacy policy</h2>

        <h3 class="font-semibold text-dusk mt-6 mb-2">Data collected</h3>
        <p class="text-sm">
          The contact form collects the following information: name, email address, arrival and departure dates, number of guests, and a free-text message. This data is collected solely to respond to your enquiries and booking requests.
        </p>

        <h3 class="font-semibold text-dusk mt-6 mb-2">Data controller</h3>
        <p class="text-sm">
          Danielle Duchenne, 5 rue des Tisserands, 34800 Villeneuvette, France — <a href="mailto:dany@location-etoiledelamer-capdagde.fr" class="text-mer hover:underline">dany@location-etoiledelamer-capdagde.fr</a>
        </p>

        <h3 class="font-semibold text-dusk mt-6 mb-2">Data processor</h3>
        <p class="text-sm">
          Messages submitted via the contact form are transmitted by <a href="https://web3forms.com" target="_blank" rel="noopener noreferrer" class="text-mer hover:underline">Web3Forms</a> (Web3Forms LLC), acting as a data processor under GDPR. Data is not retained by Web3Forms beyond transmission.
        </p>

        <h3 class="font-semibold text-dusk mt-6 mb-2">Retention period</h3>
        <p class="text-sm">
          Personal data submitted via the contact form is retained by the site publisher for the time necessary to process your request, and for a maximum of 2 years.
        </p>

        <h3 class="font-semibold text-dusk mt-6 mb-2">Your rights</h3>
        <p class="text-sm">
          Under the General Data Protection Regulation (GDPR), you have the right to access, correct, and delete your personal data. To exercise these rights, contact: <a href="mailto:dany@location-etoiledelamer-capdagde.fr" class="text-mer hover:underline">dany@location-etoiledelamer-capdagde.fr</a>
        </p>
        <p class="text-sm mt-2">
          You also have the right to lodge a complaint with the <a href="https://www.cnil.fr" target="_blank" rel="noopener noreferrer" class="text-mer hover:underline">CNIL</a> (French data protection authority).
        </p>
      </section>

      <section>
        <h2 class="font-display text-2xl text-dusk mb-4">Cookies</h2>
        <p class="text-sm">
          This website does not use tracking or analytics cookies. No third-party advertising cookies are stored on your device.
        </p>
      </section>

      <section>
        <h2 class="font-display text-2xl text-dusk mb-4">Intellectual property</h2>
        <p class="text-sm">
          All content on this website (text, photographs) is the property of Danielle Duchenne and is protected by copyright. Reproduction without prior authorisation is prohibited.
        </p>
      </section>

    </div>
  </main>
  <Footer lang={lang} />
</Base>
