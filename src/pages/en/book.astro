---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import ContactForm from '../../components/ContactForm.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n';
import { paymentConditions, weeklyRates, tarifsLabels } from '../../data/tarifs';

const lang = 'en' as const;
const t = useTranslations(lang);
const labels = tarifsLabels[lang];

const conditionItems = t('book.conditions_placeholder')
  .split('\n')
  .filter(l => l.trim())
  .map(l => l.replace(/^[•]\s*/, ''));

const platforms = [
  {
    name: 'Airbnb',
    label: t('book.airbnb_label'),
    href: 'https://www.airbnb.fr/rooms/1220166769977468167',
    bg: 'bg-[#FF385C]',
  },
  {
    name: 'Le Bon Coin',
    label: t('book.lbc_label'),
    href: 'https://www.leboncoin.fr/ad/locations_saisonnieres/2027907352',
    bg: 'bg-[#F56B2A]',
  },
];
---
<Base
  lang={lang}
  title={t('meta.book.title')}
  description={t('meta.book.description')}
>
  <Nav lang={lang} currentUrl={Astro.url} />
  <main class="pt-10">
    <div class="bg-mer-dark text-white py-10 px-4">
      <div class="max-w-6xl mx-auto text-center">
        <h1 class="font-display text-5xl font-bold mb-3">{t('book.title')}</h1>
        <p class="text-white/65 max-w-xl mx-auto leading-relaxed">{t('book.direct_intro')}</p>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-16">

        <div class="lg:col-span-2 space-y-12">
          <div>
            <h2 class="font-display text-2xl text-dusk mb-4">{t('book.conditions_title')}</h2>
            <ul class="bg-ecume rounded-2xl p-6 text-sm text-muted leading-relaxed space-y-2">
              {conditionItems.map(item => (
                <li class="flex gap-2.5">
                  <span class="text-sable shrink-0 mt-0.5">•</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div>
            <h2 class="font-display text-2xl text-dusk mb-6">{t('book.tarifs_title')}</h2>

            <p class="text-xs font-semibold text-dusk uppercase tracking-wide mb-2">{labels.paymentTitle}</p>
            <ul class="bg-ecume rounded-2xl p-6 text-sm text-muted leading-relaxed space-y-2 mb-8">
              {paymentConditions[lang].map(item => (
                <li class="flex gap-2.5">
                  <span class="text-sable shrink-0 mt-0.5">•</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <div class="flex items-baseline justify-between mb-3">
              <p class="text-xs font-semibold text-dusk uppercase tracking-wide">{labels.weeklyTitle}</p>
              <p class="text-xs text-muted">{labels.availability}</p>
            </div>
            <div class="overflow-hidden rounded-2xl border border-sable-dark/20">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-mer-dark text-white text-xs uppercase tracking-wide">
                    <th class="text-left px-5 py-3 font-semibold">{labels.colPeriod}</th>
                    <th class="text-right px-5 py-3 font-semibold">{labels.colPrice}</th>
                    <th class="text-left px-5 py-3 font-semibold hidden sm:table-cell">{labels.colNote}</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-sable-dark/10">
                  {weeklyRates.map((r, i) => (
                    <tr class={i % 2 === 0 ? 'bg-white' : 'bg-ecume'}>
                      <td class="px-5 py-3 text-dusk font-medium">
                        {r.period[lang]}
                        {r.note && <p class="text-xs text-muted font-normal sm:hidden">{r.note[lang]}</p>}
                      </td>
                      <td class="px-5 py-3 text-right font-bold text-dusk whitespace-nowrap">{r.price} €</td>
                      <td class="px-5 py-3 text-muted hidden sm:table-cell">{r.note?.[lang] ?? '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="text-xs text-muted mt-3 italic">{labels.cta}</p>
          </div>

          <ContactForm lang={lang} />
          <FAQ lang={lang} inline />
        </div>

        <aside>
          <h2 class="font-display text-2xl text-dusk mb-2">{t('book.platforms_title')}</h2>
          <p class="text-xs text-muted mb-6 leading-relaxed">{t('book.direct_note')}</p>
          <div class="space-y-4">
            {platforms.map(p => (
              <a
                href={p.href}
                target="_blank"
                rel="noopener noreferrer"
                class={`flex items-center justify-between ${p.bg} text-white rounded-2xl px-6 py-5 shadow-md hover:scale-[1.02] transition-transform duration-200`}
              >
                <div>
                  <p class="font-semibold text-base">{p.name}</p>
                  <p class="text-xs text-white/75 mt-0.5">{p.label}</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/70 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            ))}
          </div>
        </aside>

      </div>
    </div>
  </main>
  <Footer lang={lang} />
</Base>
