---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Gallery from '../../components/Gallery.astro';
import GalleryModal from '../../components/GalleryModal.astro';
import Amenities from '../../components/Amenities.astro';
import Map from '../../components/Map.astro';
import Reviews from '../../components/Reviews.astro';
import SchemaLodging from '../../components/SchemaLodging.astro';
import Footer from '../../components/Footer.astro';

const lang = 'fr' as const;
const description = "Location saisonnière T2 classé 2 étoiles au Cap d'Agde. Terrasse loggia, parking privatif, plage à 15 min à pied. 4 personnes. Réservez en direct.";
---
<Base
  lang={lang}
  title="Étoile de la Mer — Location saisonnière au Cap d'Agde"
  description={description}
  preloadHero
>
  <SchemaLodging lang={lang} description={description} />
  <Nav lang={lang} currentUrl={Astro.url} />
  <main class="pt-16">
    <Hero lang={lang} />
    <Gallery lang={lang} />
    <Amenities lang={lang} />
    <Map lang={lang} />
    <Reviews lang={lang} />
  </main>
  <GalleryModal lang={lang} />
  <Footer lang={lang} />
</Base>
