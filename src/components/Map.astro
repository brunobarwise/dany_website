---
import type { Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

/*
  Zone center = geocoded real address (Nominatim / OSM).
  A 500 m circle conveys the neighbourhood without revealing the exact building.
  POI coordinates are for publicly known places — no privacy concern.
*/
const MAP_LAT = 43.277;    // map centre (what the camera looks at)
const MAP_LNG = 3.50;

const ZONE_LAT = 43.282741;   // privacy circle centre (approximate property location)
const ZONE_LNG = 3.498319;
const ZONE_RADIUS = 500;

type Poi = {
  lat: number;
  lng: number;
  icon: string;
  label: { fr: string; en: string };
};

const pois: Poi[] = [
  {
    lat: 43.2762,
    lng: 3.5149,
    icon: '🏖️',
    label: { fr: 'Plage Grande Conque', en: 'Grande Conque beach — 15 min walk' },
  },
  {
    lat: 43.27492,
    lng: 3.49857,
    icon: '🏖️',
    label: { fr: 'Plage Richelieu — 15 min à pied, 5 min en vélo', en: 'Plage Richelieu — 15 min walk, 5 min bike' },
  },
  {
    lat: 43.274524,
    lng: 3.489972,
    icon: '🏖️',
    label: { fr: 'Plage de Rochelongue — 15 min à pied, 5 min en vélo', en: 'Plage de Rochelongue — 15 min walk, 5 min bike' },
  },
  {
    lat: 43.2869,
    lng: 3.5137,
    icon: '🏛️',
    label: { fr: "Musée de l'Éphèbe et d'archéologie sous-marine", en: "Musée de l'Éphèbe — underwater archaeology museum" },
  },
  {
    lat: 43.28052,
    lng: 3.50917,
    icon: '⛵',
    label: { fr: 'Port du Cap d\'Agde', en: 'Cap d\'Agde harbour' },
  },
  {
    lat: 43.28500022449337,
    lng: 3.5102912691418573,
    icon: '🍽️',
    label: { fr: 'Restaurants & bars du port', en: 'Harbour restaurants & bars' },
  },
  {
    lat: 43.284180521483364,
    lng: 3.4945570647225157,
    icon: '⛳',
    label: { fr: 'Golf du Cap d\'Agde', en: 'Cap d\'Agde Golf' },
  },
  {
    lat: 43.28970465450671,
    lng: 3.50959521299661,
    icon: '🎾',
    label: { fr: 'Tennis', en: 'Tennis' },
  },
  {
    lat: 43.287328,
    lng: 3.508877,
    icon: '🥖',
    label: { fr: 'Marché — samedi matin', en: 'Market — Saturday mornings' },
  },
  {
    lat: 43.28315204412442,
    lng: 3.497542959831209,
    icon: '🛒',
    label: { fr: 'Commerces & supermarchés', en: 'Shops & supermarkets' },
  },
  {
    lat: 43.283295979973786,
    lng: 3.499689507350922,
    icon: '🚴',
    label: { fr: 'Pistes cyclables', en: 'Cycling paths' },
  },
  {
    lat: 43.27975,
    lng: 3.49706,
    icon: '🌊',
    label: { fr: 'Aqualand', en: 'Aqualand' },
  },
  {
    lat: 43.27928,
    lng: 3.50365,
    icon: '🎡',
    label: { fr: 'Luna Park', en: 'Luna Park' },
  },
  {
    lat: 43.26332,
    lng: 3.50159,
    icon: '🏯',
    label: { fr: 'Fort de Brescou', en: 'Brescou Fort' },
  },
  {
    lat: 43.277793,
    lng: 3.506098,
    icon: '🎰',
    label: { fr: 'Casino du Cap d\'Agde', en: 'Cap d\'Agde Casino' },
  },
];

const heading = lang === 'fr' ? 'Localisation' : 'Location';
const subheading = lang === 'fr'
  ? "Cap d'Agde, Hérault — à deux pas de la mer"
  : "Cap d'Agde, Hérault — steps from the sea";
const zoneLabel = lang === 'fr' ? "Quartier Étoile de la Mer" : "Étoile de la Mer area";
---
<section id="map" class="py-10 bg-ecume">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="font-display text-4xl text-center text-dusk mb-3">{heading}</h2>
    <p class="text-center text-muted text-sm mb-10">{subheading}</p>
    <div
      id="leaflet-map"
      class="relative z-0 h-[480px] rounded-2xl overflow-hidden shadow-xl"
      data-config={JSON.stringify({ MAP_LAT, MAP_LNG, ZONE_LAT, ZONE_LNG, ZONE_RADIUS, pois, zoneLabel, lang })}
    ></div>
  </div>
</section>

<script>
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  type Poi = { lat: number; lng: number; icon: string; label: Record<string, string> };

  const el = document.getElementById('leaflet-map')!;
  const { MAP_LAT, MAP_LNG, ZONE_LAT, ZONE_LNG, ZONE_RADIUS, pois, zoneLabel, lang } =
    JSON.parse(el.dataset.config!) as {
      MAP_LAT: number; MAP_LNG: number;
      ZONE_LAT: number; ZONE_LNG: number; ZONE_RADIUS: number;
      pois: Poi[]; zoneLabel: string; lang: string;
    };

  const map = L.map(el, { scrollWheelZoom: false, zoomControl: true })
    .setView([MAP_LAT, MAP_LNG], 14);

  L.tileLayer(
    'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',
    {
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors ' +
        '&copy; <a href="https://carto.com/attributions">CARTO</a>',
      subdomains: 'abcd',
      maxZoom: 19,
    }
  ).addTo(map);

  L.circle([ZONE_LAT, ZONE_LNG], {
    radius: ZONE_RADIUS,
    color: '#0B3B6A',
    fillColor: '#1EACB7',
    fillOpacity: 0.20,
    weight: 2.5,
    opacity: 0.70,
  }).addTo(map).bindPopup(zoneLabel);

  pois.forEach((poi: Poi) => {
    const icon = L.divIcon({
      className: '',
      html:
        '<div style="font-size:22px;line-height:1;filter:drop-shadow(0 1px 2px rgba(0,0,0,0.35));">' +
        poi.icon +
        '</div>',
      iconSize: [28, 28],
      iconAnchor: [14, 14],
      popupAnchor: [0, -16],
    });
    L.marker([poi.lat, poi.lng], { icon })
      .addTo(map)
      .bindPopup(
        '<span style="font-size:13px;font-family:system-ui,sans-serif;">' +
        poi.label[lang] +
        '</span>'
      );
  });
</script>
