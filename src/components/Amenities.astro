---
import type { Lang } from '../i18n';
import { useTranslations } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

type Group = {
  label: { fr: string; en: string };
  items: { fr: string; en: string }[];
};

const groups: Group[] = [
  {
    label: { fr: 'Couchages', en: 'Sleeping' },
    items: [
      { fr: '4 personnes maximum', en: 'Up to 4 guests' },
      { fr: '1 chambre - lits jumeaux', en: '1 bedroom - twin beds' },
      { fr: '1 cabine - 2 lits superposés', en: '1 cabin - bunk beds' },
      { fr: 'Linge de lit en location - offert à partir de 7 nuits', en: 'Bed linen rental - free for stays of 7 nights or more' },
    ],
  },
  {
    label: { fr: 'Salle de bain', en: 'Bathroom' },
    items: [
      { fr: 'Douche', en: 'Shower' },
      { fr: 'WC séparé', en: 'Separate WC' },
      { fr: 'Sèche cheveux', en: 'Hair dryer' },
      { fr: 'Fer à repasser', en: 'Iron' },
      { fr: 'Produits bio à disposition', en: 'Organic toiletries provided' },
    ],
  },
  {
    label: { fr: 'Cuisine', en: 'Kitchen' },
    items: [
      { fr: 'Cuisine entièrement équipée', en: 'Fully equipped kitchen' },
      { fr: 'Cafetière Senseo et bouilloire', en: 'Senseo coffee maker and ketlle' },
      { fr: 'Plaques vitrocéramiques', en: 'Ceramic hobs' },
      { fr: 'Frigo et compartiment congélateur', en: 'Fridge with freezer drawer' },
      { fr: 'Petit four', en: 'Small oven' },
      { fr: 'Barbecue électrique', en: 'Electric BBQ' },
      { fr: 'Grille pain', en: 'Toaster' },
      { fr: 'Lave-linge', en: 'Washing machine' },
    ],
  },
  {
    label: { fr: 'Extérieur', en: 'Outdoor' },
    items: [
      { fr: 'Terrasse loggia couverte', en: 'Covered loggia terrace' },
      { fr: 'Très belle vue jardin', en: 'Beautiful garden view' },
      { fr: 'Parking privatif', en: 'Private parking' },
      { fr: 'Résidence sécurisée', en: 'Secured residence' },
    ],
  },
  {
    label: { fr: 'Pratique', en: 'Practical' },
    items: [
      { fr: 'Nombreux rangements', en: 'Plenty of storage space' },
      { fr: 'Appartement traversant, plein sud', en: 'Through apartment, south-facing' },
      { fr: 'Très bien ventilé (sans clim.)', en: 'Well-ventilated (no AC)' },
      { fr: 'Ventilateur', en: 'Fan' },
      { fr: 'Très bonne réception 4G/5G', en: 'Excellent 4G/5G reception' },
      { fr: 'Sans WiFi fixe', en: 'No fixed WiFi' },
    ],
  },
];
---
<section id="amenities" class="py-10 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <p class="text-center text-xs font-semibold tracking-widest uppercase text-mer/60 mb-3">
      {t('amenities.classification')}
    </p>
    <h2 class="font-display text-4xl text-center text-dusk mb-4">{t('amenities.title')}</h2>
    <p class="text-center text-muted max-w-xl mx-auto mb-12 leading-relaxed">
      {t('amenities.description')}
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {groups.map(group => (
        <div class="bg-ecume rounded-2xl p-6">
          <h3 class="font-semibold text-mer text-xs uppercase tracking-widest mb-4">
            {group.label[lang]}
          </h3>
          <ul class="space-y-2.5">
            {group.items.map(item => (
              <li class="flex items-start gap-2.5 text-sm text-dusk">
                <span class="text-turquoise mt-px shrink-0 font-bold">✓</span>
                <span>{item[lang]}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </div>
</section>
