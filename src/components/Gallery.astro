---
import type { Lang } from '../i18n';
import { useTranslations } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

/*
  Add images here once photos are provided.
  Store files in public/images/gallery/ as WebP, max 200 KB each.
  Recommended: 8–16 photos covering interior, bedroom, terrace, exterior.
*/
const images: { src: string; alt: string }[] = [
  // { src: '/images/gallery/01.jpg', alt: 'Séjour lumineux' },
  // { src: '/images/gallery/02.jpg', alt: 'Chambre' },
  // { src: '/images/gallery/03.jpg', alt: 'Terrasse loggia' },
];

const hasImages = images.length > 0;
---
<section id="gallery" class="py-10 bg-ecume">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="font-display text-4xl text-center text-dusk mb-12">{t('gallery.title')}</h2>

    {hasImages ? (
      <div class="swiper gallery-swiper rounded-2xl overflow-hidden shadow-xl">
        <div class="swiper-wrapper">
          {images.map(img => (
            <div class="swiper-slide">
              <img src={img.src} alt={img.alt} class="w-full h-[60vh] object-cover" loading="lazy" />
            </div>
          ))}
        </div>
        <div class="swiper-pagination"></div>
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
      </div>
    ) : (
      <div class="rounded-2xl bg-mer/5 border-2 border-dashed border-mer/20 h-64 flex flex-col items-center justify-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-mer/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <p class="text-dusk/40 text-sm">{t('gallery.placeholder')}</p>
      </div>
    )}
  </div>
</section>

{hasImages && (
  <Fragment>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script is:inline>
      new Swiper('.gallery-swiper', {
        loop: true,
        pagination: { el: '.swiper-pagination', clickable: true },
        navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
        keyboard: { enabled: true },
      });
    </script>
  </Fragment>
)}
