---
import type { Lang } from '../i18n';
import { useTranslations, getAlternateUrl } from '../i18n';

interface Props {
  lang: Lang;
  currentUrl: URL;
}

const { lang, currentUrl } = Astro.props;
const t = useTranslations(lang);
const alternate = getAlternateUrl(currentUrl);
const altLabel = lang === 'fr' ? 'EN 🇬🇧' : 'FR 🇫🇷';

const homeHref = `/${lang}`;
const aroundHref = lang === 'fr' ? '/fr/autour' : '/en/around';
const bookHref = lang === 'fr' ? '/fr/reserver' : '/en/book';

const path = currentUrl.pathname.replace(/\/$/, '');
const isActive = (href: string) => path === href;
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-sable/30 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
    <a href={homeHref} class="font-display text-lg font-bold text-mer-dark tracking-tight shrink-0">
      Étoile de la Mer - Cap d'Agde
    </a>

    <div class="hidden md:flex items-center gap-7">
      <a
        href={homeHref}
        class:list={['text-sm font-medium transition-colors', isActive(homeHref) ? 'text-mer' : 'text-dusk/70 hover:text-mer']}
      >
        {t('nav.home')}
      </a>
      <a
        href={aroundHref}
        class:list={['text-sm font-medium transition-colors', isActive(aroundHref) ? 'text-mer' : 'text-dusk/70 hover:text-mer']}
      >
        {t('nav.around')}
      </a>
      <a
        href={bookHref}
        class="text-sm font-semibold bg-sable text-white px-5 py-2 rounded-full hover:bg-sable-dark transition-colors"
      >
        {t('nav.book')}
      </a>
      <a
        href={alternate}
        class="text-xs font-semibold text-muted hover:text-mer border border-dusk/20 rounded-full px-3 py-1.5 min-h-[44px] inline-flex items-center transition-colors"
      >
        {altLabel}
      </a>
    </div>

    <button id="nav-toggle" class="md:hidden p-2.5 text-dusk/70" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <div id="nav-mobile" class="hidden md:hidden border-t border-sable/20 bg-white px-6 py-4 space-y-3">
    <a href={homeHref} class="block text-sm font-medium text-dusk hover:text-mer">{t('nav.home')}</a>
    <a href={aroundHref} class="block text-sm font-medium text-dusk hover:text-mer">{t('nav.around')}</a>
    <a href={bookHref} class="block text-sm font-semibold text-mer">{t('nav.book')}</a>
    <a href={alternate} class="block text-xs font-semibold text-muted min-h-[44px] flex items-center">{altLabel}</a>
  </div>
</nav>

<script>
  const toggle = document.getElementById('nav-toggle');
  const mobile = document.getElementById('nav-mobile');
  toggle?.addEventListener('click', () => mobile?.classList.toggle('hidden'));
</script>
