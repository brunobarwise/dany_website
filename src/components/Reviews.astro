---
import type { Lang } from '../i18n';
import { useTranslations } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

/*
  PLACEHOLDER reviews — replace with real testimonials once obtained.
  Written consent required per reviewer before publishing.
*/
type Review = {
  name: string;
  stars: number;
  text: { fr: string; en: string };
  date: { fr: string; en: string };
};

const reviews: Review[] = [
  {
    name: 'Nicole B.',
    stars: 5,
    text: {
      fr: 'Logement très bien placé, accueil des propriétaires très chaleureux. Super d’avoir une chambre indépendante, très calme. Nous avons apprécié de pouvoir faire à pied les courses et nous rendre à la plage. Bonne location de vacances.',
      en: 'The accommodation is in a great location, and the owners gave us a very warm welcome. It was lovely to have a separate bedroom; it was very quiet. We really appreciated being able to walk to the shops and the beach. A great holiday rental.',
    },
    date: { fr: 'Octobre 2025', en: 'October 2025' },
  },
  {
    name: 'Eve et Philippe A.',
    stars: 5,
    text: {
      fr: 'Séjour très agréable dans cet appartement. Le logement est très propre et au calme tout en étant proche des commerces. Nous recommandons !',
      en: 'We had a very pleasant stay in this flat. The accommodation is very clean and quiet, yet close to the shops. We highly recommend it!',
    },
    date: { fr: 'Juillet 2025', en: 'July 2025' },
  },
  {
    name: 'Odile M.',
    stars: 5,
    text: {
      fr: 'Petit appartement au calme, très bien agencé, très agréable avec son balcon. Très propre et pratique, rien ne manque, je le recommande.',
      en: 'A small, quiet flat, very well laid out and lovely with its balcony. Very clean and practical, with everything you need. I highly recommend it. ',
    },
    date: { fr: 'Juin 2025', en: 'June 2025' },
  },
  {
    name: 'Vanessa B.',
    stars: 5,
    text: {
      fr: 'Au calme, parking super. Beau weekend entre farniente au port et visite du musée de l\'Éphèbe.',
      en: 'Quiet neighbourhood, excellent parking. A lovely weekend spent relaxing at the harbour and visiting the Musée de l\'Éphèbe.',
    },
    date: { fr: 'Mai 2025', en: 'May 2025' },
  },
];
---
<section id="reviews" class="pt-10 pb-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <h2 class="font-display text-4xl text-center text-dusk mb-12">{t('reviews.title')}</h2>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      {reviews.map(r => (
        <div class="bg-ecume rounded-2xl p-6 shadow-sm">
          <div class="flex gap-1 mb-4">
            {Array.from({ length: r.stars }).map(() => (
              <svg class="w-4 h-4 text-sable" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.162c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.364 1.118l1.287 3.957c.3.921-.755 1.688-1.54 1.118l-3.37-2.448a1 1 0 00-1.175 0l-3.37 2.448c-.784.57-1.838-.197-1.539-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.062 9.384c-.783-.57-.38-1.81.588-1.81h4.162a1 1 0 00.95-.69L9.049 2.927z" />
              </svg>
            ))}
          </div>
          <p class="text-dusk text-sm italic mb-4 leading-relaxed">"{r.text[lang]}"</p>
          <p class="font-semibold text-mer text-sm">
            {r.name}
            <span class="text-dusk/40 font-normal"> · {r.date[lang]}</span>
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
