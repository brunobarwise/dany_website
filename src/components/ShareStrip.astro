---
import type { Lang } from '../i18n';
import { useTranslations } from '../i18n';

interface Props {
  lang: Lang;
  compact?: boolean;
}

const { lang, compact = false } = Astro.props;
const t = useTranslations(lang);

type ChannelId = 'whatsapp' | 'facebook' | 'email' | 'sms' | 'copy';

const channels: { id: ChannelId; label: string }[] = [
  { id: 'whatsapp', label: 'WhatsApp' },
  { id: 'facebook', label: 'Facebook' },
  { id: 'email',    label: t('share.email') },
  { id: 'sms',      label: 'SMS' },
  { id: 'copy',     label: t('share.copy') },
];

const icons: Record<ChannelId, string> = {
  whatsapp: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
  facebook: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>`,
  email:    `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  sms:      `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  copy:     `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`,
};
---

{compact ? (
  <div class="flex items-center gap-3">
    {channels.map(ch => (
      <button
        type="button"
        data-share={ch.id}
        data-copied={t('share.copied')}
        class="w-9 h-9 rounded-full flex items-center justify-center text-white/40 hover:text-white/75 transition-colors cursor-pointer"
        aria-label={ch.label}
        title={ch.label}
      >
        <span class="share-icon flex items-center justify-center pointer-events-none" set:html={icons[ch.id]} />
      </button>
    ))}
  </div>
) : (
  <section class="py-12 bg-ecume">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-xs font-semibold text-dusk uppercase tracking-widest mb-8">{t('share.title')}</p>
      <div class="flex justify-center gap-6 sm:gap-10 flex-wrap">
        {channels.map(ch => (
          <button
            type="button"
            data-share={ch.id}
            data-copied={t('share.copied')}
            class="flex flex-col items-center gap-2 group cursor-pointer"
            aria-label={ch.label}
          >
            <span class="w-12 h-12 rounded-full bg-white shadow-sm flex items-center justify-center text-dusk group-hover:text-mer group-hover:shadow-md transition-all duration-200">
              <span class="share-icon flex items-center justify-center pointer-events-none" set:html={icons[ch.id]} />
            </span>
            <span class="text-xs text-muted group-hover:text-dusk transition-colors share-label">
              {ch.label}
            </span>
          </button>
        ))}
      </div>
    </div>
  </section>
)}

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-share]').forEach(btn => {
    btn.addEventListener('click', async () => {
      const type = btn.dataset.share!;

      if (type === 'copy') {
        try {
          await navigator.clipboard.writeText(window.location.href);
        } catch {
          return;
        }
        const labelEl = btn.querySelector<HTMLElement>('.share-label');
        const iconEl  = btn.querySelector<HTMLElement>('.share-icon');
        const copied  = btn.dataset.copied ?? '✓';
        if (labelEl) {
          const orig = labelEl.textContent ?? '';
          labelEl.textContent = copied;
          setTimeout(() => { labelEl.textContent = orig; }, 2000);
        } else if (iconEl) {
          const orig = iconEl.innerHTML;
          iconEl.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><polyline points="20 6 9 17 4 12"/></svg>';
          setTimeout(() => { iconEl.innerHTML = orig; }, 2000);
        }
        return;
      }

      const url   = encodeURIComponent(window.location.href);
      const title = encodeURIComponent(document.title);
      const targets: Record<string, string> = {
        whatsapp: `https://wa.me/?text=${url}`,
        facebook: `https://www.facebook.com/sharer/sharer.php?u=${url}`,
        email:    `mailto:?subject=${title}&body=${url}`,
        sms:      `sms:?body=${url}`,
      };
      const href = targets[type];
      if (!href) return;
      if (type === 'email' || type === 'sms') {
        window.location.href = href;
      } else {
        window.open(href, '_blank', 'noopener,noreferrer,width=600,height=500');
      }
    });
  });
</script>